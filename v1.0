# Simplified-EntraRoleAudit.ps1
# Version: 1.0
# Purpose: Audit Microsoft Entra directory role assignments using Microsoft Graph PowerShell.
# Output: One CSV file containing summary, active role assignments, and optional PIM eligibility rows.
# Supports interactive delegated sign-in, device code sign-in, or app-only certificate authentication.
# Delegated auth uses scopes. App-only auth uses application permissions such as RoleManagement.Read.All, Directory.Read.All, User.Read.All, Group.Read.All, and Application.Read.All.
#Requires -Version 5.1
[CmdletBinding()]
param(
    [ValidateSet("Auto","Interactive","DeviceCode","Certificate")]
    [string]$ConnectionMode = "Auto",
    [string]$TenantId,
    [string]$ClientId,
    [string]$CertificateThumbprint,
    [string]$OutputPath = ".\EntraRoleAudit_$(Get-Date -Format 'yyyyMMdd_HHmmss')",
    [string]$OutputFileName = "EntraRoleAudit.csv",
    [string[]]$RoleNames = @(
        "Global Administrator",
        "Privileged Role Administrator",
        "Security Administrator",
        "Security Reader",
        "Global Reader",
        "User Administrator",
        "Application Administrator",
        "Cloud Application Administrator",
        "Conditional Access Administrator",
        "Authentication Administrator",
        "Privileged Authentication Administrator",
        "Intune Administrator",
        "Compliance Administrator"
    ),
    [switch]$IncludePIM,
    [switch]$IncludeGroupMembers,
    [switch]$AllRoles,
    [switch]$NonInteractive
)
function Write-Section { param([string]$Text) Write-Host ""; Write-Host ("=" * 72) -ForegroundColor Cyan; Write-Host " $Text" -ForegroundColor Cyan; Write-Host ("=" * 72) -ForegroundColor Cyan }
function Write-Step { param([string]$Text) Write-Host "  > $Text" -ForegroundColor Yellow }
function Write-Ok { param([string]$Text) Write-Host "  [OK] $Text" -ForegroundColor Green }
function Write-Warn2 { param([string]$Text) Write-Host "  [WARN] $Text" -ForegroundColor DarkYellow }
function Stop-WithMessage { param([string]$Text) Write-Host ""; Write-Host "ERROR: $Text" -ForegroundColor Red; throw $Text }
function Read-InputValue { param([string]$CurrentValue,[string]$Prompt,[string]$Name) if (-not [string]::IsNullOrWhiteSpace($CurrentValue)) { return $CurrentValue } if ($NonInteractive) { Stop-WithMessage "$Name is required when using -NonInteractive." } $value = Read-Host $Prompt; if ([string]::IsNullOrWhiteSpace($value)) { Stop-WithMessage "$Name is required." } return $value }
function Select-ConnectionMode { if ($ConnectionMode -ne "Auto") { return $ConnectionMode } if ($NonInteractive) { Stop-WithMessage "ConnectionMode is required when using -NonInteractive. Use -ConnectionMode Certificate with ClientId and CertificateThumbprint, or choose Interactive or DeviceCode without -NonInteractive." } Write-Host ""; Write-Host "Select Microsoft Graph connection method:" -ForegroundColor Cyan; Write-Host "  1. Interactive browser sign-in (delegated)"; Write-Host "  2. Device code sign-in (delegated)"; Write-Host "  3. App-only certificate authentication"; $choice = Read-Host "Enter 1, 2, or 3"; switch ($choice) { "1" { return "Interactive" } "2" { return "DeviceCode" } "3" { return "Certificate" } default { Stop-WithMessage "Invalid connection option selected." } } }
function Read-YesNo { param([string]$Prompt,[bool]$Default = $false) if ($NonInteractive) { return $Default } $suffix = if ($Default) { "Y/n" } else { "y/N" }; while ($true) { $answer = Read-Host "$Prompt [$suffix]"; if ([string]::IsNullOrWhiteSpace($answer)) { return $Default } switch ($answer.Trim().ToLowerInvariant()) { "y" { return $true } "yes" { return $true } "n" { return $false } "no" { return $false } default { Write-Warn2 "Enter Y or N." } } } }
function Initialize-RunOptions { if (-not $PSBoundParameters.ContainsKey("OutputPath") -and -not $NonInteractive) { $defaultOutputPath = $OutputPath; $enteredOutputPath = Read-Host "Output folder [$defaultOutputPath]"; if (-not [string]::IsNullOrWhiteSpace($enteredOutputPath)) { $script:OutputPath = $enteredOutputPath } else { $script:OutputPath = $defaultOutputPath } } else { $script:OutputPath = $OutputPath } if (-not $PSBoundParameters.ContainsKey("IncludePIM")) { $includePimAnswer = Read-YesNo -Prompt "Include PIM eligible role assignments" -Default $false; if ($includePimAnswer) { $script:IncludePIM = $true } } if (-not (Test-Path $script:OutputPath)) { New-Item -ItemType Directory -Path $script:OutputPath -Force | Out-Null } $script:OutputFilePath = Join-Path $script:OutputPath $OutputFileName; if (Test-Path $script:OutputFilePath) { Remove-Item $script:OutputFilePath -Force } Write-Ok "Output CSV set to $script:OutputFilePath"; Write-Ok "Include PIM eligible assignments: $($script:IncludePIM.IsPresent -or [bool]$script:IncludePIM)" }
function Add-RecordType { param([object[]]$Data,[string]$RecordType) foreach ($item in @($Data)) { $item | Add-Member -NotePropertyName RecordType -NotePropertyValue $RecordType -Force; $item } }
function Initialize-GraphModules { $modules = @("Microsoft.Graph.Authentication","Microsoft.Graph.Identity.DirectoryManagement","Microsoft.Graph.Users","Microsoft.Graph.Groups","Microsoft.Graph.Applications") ; if ($script:IncludePIM -or $IncludePIM) { $modules += "Microsoft.Graph.Identity.Governance" } foreach ($module in ($modules | Sort-Object -Unique)) { if (-not (Get-Module -ListAvailable -Name $module)) { Write-Step "Installing missing module: $module"; Install-Module -Name $module -Scope CurrentUser -Force -AllowClobber -ErrorAction Stop } Import-Module $module -Force -ErrorAction Stop; Write-Ok "Loaded module: $module" } }
function Connect-EntraAuditGraph { $script:ConnectionModeUsed = Select-ConnectionMode; $scopes = @("RoleManagement.Read.Directory","Directory.Read.All","User.Read.All","Group.Read.All","Application.Read.All") ; if ($script:IncludePIM -or $IncludePIM) { $scopes += "RoleEligibilitySchedule.Read.Directory" } Write-Step "Connecting to Microsoft Graph using $script:ConnectionModeUsed mode"; Disconnect-MgGraph -ErrorAction SilentlyContinue | Out-Null; switch ($script:ConnectionModeUsed) { "Interactive" { if ([string]::IsNullOrWhiteSpace($TenantId)) { Connect-MgGraph -Scopes $scopes -NoWelcome -ErrorAction Stop } else { Connect-MgGraph -TenantId $TenantId -Scopes $scopes -NoWelcome -ErrorAction Stop } } "DeviceCode" { if ([string]::IsNullOrWhiteSpace($TenantId)) { Connect-MgGraph -Scopes $scopes -UseDeviceCode -NoWelcome -ErrorAction Stop } else { Connect-MgGraph -TenantId $TenantId -Scopes $scopes -UseDeviceCode -NoWelcome -ErrorAction Stop } } "Certificate" { $script:ClientId = Read-InputValue -CurrentValue $ClientId -Prompt "App registration client ID" -Name "ClientId"; $script:CertificateThumbprint = Read-InputValue -CurrentValue $CertificateThumbprint -Prompt "Certificate thumbprint" -Name "CertificateThumbprint"; if ([string]::IsNullOrWhiteSpace($TenantId)) { Stop-WithMessage "TenantId is required for certificate-based app-only authentication." } Connect-MgGraph -TenantId $TenantId -ClientId $script:ClientId -CertificateThumbprint $script:CertificateThumbprint -NoWelcome -ErrorAction Stop } } $ctx = Get-MgContext; if (-not $ctx) { Stop-WithMessage "Microsoft Graph connection did not return a context." } $script:TenantId = $ctx.TenantId; if ([string]::IsNullOrWhiteSpace($script:ClientId)) { $script:ClientId = $ctx.ClientId } Write-Ok "Connected to Microsoft Graph tenant $script:TenantId using $script:ConnectionModeUsed mode" }
function Resolve-EntraPrincipal { param([string]$PrincipalId) $user = Get-MgUser -UserId $PrincipalId -Property "Id,DisplayName,UserPrincipalName,Mail,AccountEnabled,UserType,Department,JobTitle" -ErrorAction SilentlyContinue; if ($user) { return [pscustomobject]@{Type="User";Id=$user.Id;DisplayName=$user.DisplayName;UPN=$user.UserPrincipalName;Mail=$user.Mail;AccountEnabled=$user.AccountEnabled;UserType=$user.UserType;Department=$user.Department;JobTitle=$user.JobTitle;AppId=""} } $group = Get-MgGroup -GroupId $PrincipalId -Property "Id,DisplayName,Mail" -ErrorAction SilentlyContinue; if ($group) { return [pscustomobject]@{Type="Group";Id=$group.Id;DisplayName=$group.DisplayName;UPN=$group.Mail;Mail=$group.Mail;AccountEnabled="";UserType="Group";Department="";JobTitle="";AppId=""} } $sp = Get-MgServicePrincipal -ServicePrincipalId $PrincipalId -Property "Id,DisplayName,AppId,ServicePrincipalType" -ErrorAction SilentlyContinue; if ($sp) { return [pscustomobject]@{Type="ServicePrincipal";Id=$sp.Id;DisplayName=$sp.DisplayName;UPN="";Mail="";AccountEnabled="";UserType=$sp.ServicePrincipalType;Department="";JobTitle="";AppId=$sp.AppId} } return [pscustomobject]@{Type="Unknown";Id=$PrincipalId;DisplayName=$PrincipalId;UPN="";Mail="";AccountEnabled="";UserType="Unknown";Department="";JobTitle="";AppId=""} }
function Get-EntraActiveRoleAssignments { Write-Section "Entra active directory role assignments"; $rows = @(); $roles = Get-MgDirectoryRole -All -ErrorAction Stop; if (-not $AllRoles) { $roles = $roles | Where-Object { $_.DisplayName -in $RoleNames } } Write-Ok "Roles selected for audit: $(@($roles).Count)"; foreach ($role in $roles) { Write-Step "Role: $($role.DisplayName)"; $members = Get-MgDirectoryRoleMember -DirectoryRoleId $role.Id -All -ErrorAction SilentlyContinue; foreach ($member in @($members)) { $principal = Resolve-EntraPrincipal -PrincipalId $member.Id; $rows += [pscustomobject]@{RoleName=$role.DisplayName;RoleId=$role.Id;AssignmentType="Active";PrincipalType=$principal.Type;DisplayName=$principal.DisplayName;UserPrincipalName=$principal.UPN;Mail=$principal.Mail;AccountEnabled=$principal.AccountEnabled;UserType=$principal.UserType;Department=$principal.Department;JobTitle=$principal.JobTitle;PrincipalId=$principal.Id;AppId=$principal.AppId;SourceGroup="";ScheduleStart="";ScheduleEnd="";ExpirationType="";Status="";TenantId="";ConnectionMode="";ClientId="";AllRoles="";IncludedPIM="";IncludedGroupMembers="";ActiveAssignmentRows="";PimEligibleRows="";OutputFilePath="";ExportedAt=(Get-Date -Format "yyyy-MM-dd HH:mm:ss")} ; if ($IncludeGroupMembers -and $principal.Type -eq "Group") { $groupMembers = Get-MgGroupMember -GroupId $principal.Id -All -ErrorAction SilentlyContinue; foreach ($gm in @($groupMembers)) { $gp = Resolve-EntraPrincipal -PrincipalId $gm.Id; $rows += [pscustomobject]@{RoleName=$role.DisplayName;RoleId=$role.Id;AssignmentType="Active via Group";PrincipalType=$gp.Type;DisplayName=$gp.DisplayName;UserPrincipalName=$gp.UPN;Mail=$gp.Mail;AccountEnabled=$gp.AccountEnabled;UserType=$gp.UserType;Department=$gp.Department;JobTitle=$gp.JobTitle;PrincipalId=$gp.Id;AppId=$gp.AppId;SourceGroup=$principal.DisplayName;ScheduleStart="";ScheduleEnd="";ExpirationType="";Status="";TenantId="";ConnectionMode="";ClientId="";AllRoles="";IncludedPIM="";IncludedGroupMembers="";ActiveAssignmentRows="";PimEligibleRows="";OutputFilePath="";ExportedAt=(Get-Date -Format "yyyy-MM-dd HH:mm:ss")} } } } } return $rows }
function Get-EntraPimEligibleAssignments { Write-Section "Entra PIM eligible role assignments"; $rows = @(); if (-not ($script:IncludePIM -or $IncludePIM)) { Write-Warn2 "PIM eligibility skipped."; return $rows } $eligible = Get-MgRoleManagementDirectoryRoleEligibilitySchedule -All -ErrorAction Stop; Write-Ok "Eligibility schedules found: $(@($eligible).Count)"; foreach ($item in @($eligible)) { $roleDef = Get-MgRoleManagementDirectoryRoleDefinition -UnifiedRoleDefinitionId $item.RoleDefinitionId -ErrorAction SilentlyContinue; if (-not $roleDef) { continue } if (-not $AllRoles -and $roleDef.DisplayName -notin $RoleNames) { continue } $principal = Resolve-EntraPrincipal -PrincipalId $item.PrincipalId; $rows += [pscustomobject]@{RoleName=$roleDef.DisplayName;RoleId=$item.RoleDefinitionId;AssignmentType="PIM Eligible";PrincipalType=$principal.Type;DisplayName=$principal.DisplayName;UserPrincipalName=$principal.UPN;Mail=$principal.Mail;AccountEnabled=$principal.AccountEnabled;UserType=$principal.UserType;Department=$principal.Department;JobTitle=$principal.JobTitle;PrincipalId=$principal.Id;AppId=$principal.AppId;SourceGroup="";ScheduleStart=$item.ScheduleInfo.StartDateTime;ScheduleEnd=$item.ScheduleInfo.Expiration.EndDateTime;ExpirationType=$item.ScheduleInfo.Expiration.Type;Status=$item.Status;TenantId="";ConnectionMode="";ClientId="";AllRoles="";IncludedPIM="";IncludedGroupMembers="";ActiveAssignmentRows="";PimEligibleRows="";OutputFilePath="";ExportedAt=(Get-Date -Format "yyyy-MM-dd HH:mm:ss")} } return $rows }
function Export-SingleAuditCsv { param([object[]]$ActiveRows,[object[]]$PimRows) $summary = @([pscustomobject]@{RoleName="";RoleId="";AssignmentType="Summary";PrincipalType="";DisplayName="";UserPrincipalName="";Mail="";AccountEnabled="";UserType="";Department="";JobTitle="";PrincipalId="";AppId="";SourceGroup="";ScheduleStart="";ScheduleEnd="";ExpirationType="";Status="";TenantId=$script:TenantId;ConnectionMode=$script:ConnectionModeUsed;ClientId=$script:ClientId;AllRoles=$AllRoles.IsPresent;IncludedPIM=($script:IncludePIM -or $IncludePIM);IncludedGroupMembers=$IncludeGroupMembers.IsPresent;ActiveAssignmentRows=@($ActiveRows).Count;PimEligibleRows=@($PimRows).Count;OutputFilePath=$script:OutputFilePath;ExportedAt=(Get-Date -Format "yyyy-MM-dd HH:mm:ss")}); $combined = @(); $combined += Add-RecordType -Data $summary -RecordType "Summary"; $combined += Add-RecordType -Data $ActiveRows -RecordType "ActiveRoleAssignment"; $combined += Add-RecordType -Data $PimRows -RecordType "PIMEligibleAssignment"; $combined | Export-Csv -Path $script:OutputFilePath -NoTypeInformation -Encoding UTF8; Write-Ok "Single CSV exported with $(@($combined).Count) rows"; Write-Host ""; Write-Host "CSV created:" -ForegroundColor Cyan; Write-Host "  $script:OutputFilePath" }
try { Write-Section "Microsoft Entra Role Audit"; Write-Host "This script audits Entra directory role assignments only." -ForegroundColor White; Write-Host "Connection options: Interactive, DeviceCode, or Certificate. If -ConnectionMode is not specified, the script will prompt." -ForegroundColor White; Write-Host "The script creates one CSV file only. No Excel dependency is installed." -ForegroundColor White; Write-Host ""; Initialize-RunOptions; Initialize-GraphModules; Connect-EntraAuditGraph; $activeRows = Get-EntraActiveRoleAssignments; $pimRows = Get-EntraPimEligibleAssignments; Export-SingleAuditCsv -ActiveRows $activeRows -PimRows $pimRows; Disconnect-MgGraph -ErrorAction SilentlyContinue | Out-Null; Write-Host ""; Write-Host "Done." -ForegroundColor Green } catch { Write-Host ""; Write-Host "Script stopped because of an error:" -ForegroundColor Red; Write-Host $_ -ForegroundColor Red; try { Disconnect-MgGraph -ErrorAction SilentlyContinue | Out-Null } catch {}; exit 1 }

